// NeqSim Development Container Configuration
// For format details, see https://containers.dev/implementors/json_reference/
{
	"name": "NeqSim Dev",
	"build": {
		"dockerfile": "Dockerfile",
		"args": {
			"VARIANT": "11",
			"INSTALL_MAVEN": "true",
			"MAVEN_VERSION": "3.9.12"
		}
	},
	// Add Python 3.12 for Jupyter notebook development with neqsim-python
	"features": {
		"ghcr.io/devcontainers/features/python:1": {
			"version": "3.12",
			"installJupyterlab": true
		},
		"ghcr.io/devcontainers/features/node:1": {
			"version": "lts"
		}
	},
	// Run after container creation: install neqsim-python and dev tools
	"postCreateCommand": "pip install --user neqsim matplotlib pandas numpy python-docx || true && chmod +x ./mvnw && ./mvnw dependency:resolve",
	"customizations": {
		"vscode": {
			"settings": {
				// Java settings
				"java.configuration.updateBuildConfiguration": "automatic",
				"java.compile.nullAnalysis.mode": "automatic",
				"java.format.settings.url": "neqsim_formatter.xml",
				"java.checkstyle.configuration": "${workspaceFolder}/.config/checkstyle_neqsim.xml",
				"java.test.defaultConfig": "default",
				// Editor settings
				"editor.formatOnSave": true,
				"editor.rulers": [
					120
				],
				"files.trimTrailingWhitespace": true,
				// Copilot settings — auto-approve agent actions
				"github.copilot.chat.agent.autoApprove": true,
				"github.copilot.chat.autoCommit.enabled": false,
				"github.copilot.chat.confirmEditGeneration": false,
				"chat.agent.maxRequests": 2500,
				// Terminal
				"terminal.integrated.defaultProfile.linux": "bash",
				// Python / Jupyter
				"python.defaultInterpreterPath": "/usr/local/python/current/bin/python3",
				"jupyter.notebookFileRoot": "${workspaceFolder}"
			},
			"extensions": [
				// Java development
				"redhat.java",
				"vscjava.vscode-java-pack",
				"vscjava.vscode-java-test",
				"vscjava.vscode-maven",
				"shengchen.vscode-checkstyle",
				// AI / Copilot
				"GitHub.copilot",
				"GitHub.copilot-chat",
				// Python / Jupyter
				"ms-python.python",
				"ms-toolsai.jupyter",
				// Data / CSV
				"mechatroner.rainbow-csv",
				"janisdd.vscode-edit-csv",
				// XML / Markdown
				"redhat.vscode-xml",
				"yzhang.markdown-all-in-one",
				// Git
				"mhutchie.git-graph",
				"eamodio.gitlens",
				// Utilities
				"ms-vscode.test-adapter-converter"
			]
		}
	}
}