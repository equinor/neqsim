# Auto detect text files and normalize to LF in the repo.
# Working-tree line endings are determined by the OS (core.autocrlf).
* text=auto eol=lf

# Windows batch files must have CRLF (they break with LF)
*.bat text eol=crlf
*.cmd text eol=crlf
mvnw.cmd text eol=crlf

# Java source files
*.java text diff=java eol=lf
*.properties text eol=lf
*.xml text eol=lf
*.csv text eol=lf
*.json text eol=lf
*.md text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.sh text eol=lf
mvnw text eol=lf

# Maven wrapper properties
.mvn/wrapper/maven-wrapper.properties text eol=lf

# Binary files
*.jar binary
*.class binary
*.png binary
*.jpg binary
*.gif binary
*.ico binary
*.pdf binary
