{
  // ─── Java Configuration ───
  "java.configuration.updateBuildConfiguration": "automatic",
  "java.compile.nullAnalysis.mode": "automatic",
  "[java]": {
    "editor.codeActionsOnSave": {
      "source.organizeImports": "explicit"
    },
    "editor.defaultFormatter": "redhat.java",
    "editor.formatOnSave": true,
    "editor.tabSize": 2,
    "editor.insertSpaces": true,
    "editor.detectIndentation": false
  },
  "java.format.settings.url": "${workspaceFolder}/.config/neqsim_formatter.xml",
  "java.format.settings.profile": "neqsim_formatter",
  "java.checkstyle.version": "10.26.1",
  "java.checkstyle.configuration": "${workspaceFolder}/.config/checkstyle_neqsim.xml",
  "java.test.defaultConfig": "default",
  "java.debug.settings.onBuildFailureProceed": true,
  // ─── Editor ───
  "editor.rulers": [
    120
  ],
  "files.trimTrailingWhitespace": true,
  "[xml]": {
    "editor.tabSize": 4,
    "editor.insertSpaces": false
  },
  "[json]": {
    "editor.tabSize": 4,
    "editor.insertSpaces": true
  },
  // ─── Copilot Agent Configuration ───
  // Auto-approve agent actions (file edits, terminal commands, etc.)
  "github.copilot.chat.agent.autoApprove": true,
  "github.copilot.chat.autoCommit.enabled": false,
  "github.copilot.chat.confirmEditGeneration": false,
  "chat.agent.maxRequests": 2500,
  // ─── Python / Jupyter ───
  // Default Python environment for this workspace (notebooks + terminals).
  "python.defaultInterpreterPath": "C:\\appl\\neqsim-venv\\Scripts\\python.exe",
  "python.terminal.activateEnvironment": true,
  "jupyter.notebookFileRoot": "${workspaceFolder}",
  // ─── Search Exclusions ───
  "search.exclude": {
    "**/target": true,
    "**/node_modules": true,
    "**/.git": true,
    "**/dependency-reduced-pom.xml": true
  }
}