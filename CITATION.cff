    affiliation: "Equinor / NTNU"
    orcid: "https://orcid.org/0000-0002-0203-3863"
  - name: "NeqSim contributors"
repository-code: "https://github.com/equinor/neqsim"
url: "https://equinor.github.io/neqsim/"
license: Apache-2.0
keywords:
  - thermodynamics
  - process-simulation
  - equation-of-state
  - PVT
  - oil-and-gas
