teg_stream = Stream("Lean TEG", teg_fluid)
teg_stream.setFlowRate(5000.0, "kg/hr")
teg_stream.setTemperature(30.0, "C")
teg_stream.setPressure(70.0, "bara")

print("TEG dehydration streams configured with CPA")
```

