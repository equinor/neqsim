  align(center)[#table(
    columns: 4,
    align: (auto,auto,auto,auto,),
    table.header([Rule], [$epsilon^(upright("cross")) \/ R$ (K)], [$beta^(upright("cross"))$], [Water in methanol (mol%)],),
    table.hline(),
    [CR-1], [2480], [0.034], [Fully miscible (correct)],
    [CR-2], [2440], [0.034], [Fully miscible (correct)],
