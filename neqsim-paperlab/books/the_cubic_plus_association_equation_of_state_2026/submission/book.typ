  align(center)[#table(
    columns: 6,
    align: (auto,auto,auto,auto,auto,auto,),
    table.header([], [$a_0$], [$b$], [$c_1$], [$epsilon \/ R$], [$beta$],),
    table.hline(),
    [$a_0$], [1.00], [$- 0.45$], [0.92], [0.58], [$- 0.31$],
    [$b$], [], [1.00], [$- 0.38$], [$- 0.62$], [0.55],
    [$c_1$], [], [], [1.00], [0.47], [$- 0.25$],
    [$epsilon \/ R$], [], [], [], [1.00], [$- 0.78$],
    [$beta$], [], [], [], [], [1.00],
  )]
