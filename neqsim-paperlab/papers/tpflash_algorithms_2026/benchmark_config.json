{
  "benchmark_id": "tpflash_algorithms_2026",
  "created": "2026-01-15",
  "neqsim_version": "latest",
  "algorithms": [
    {
      "name": "baseline_neqsim",
      "description": "NeqSim default TPflash: SS with DEM acceleration, switch to NR at fixed tolerance",
      "class": "neqsim.thermodynamicoperations.flashops.TPflash",
      "modifications": []
    },
    {
      "name": "candidate_combined",
      "description": "Adaptive SS-NR switch + trust-region Newton step",
      "class": "TODO: implement as modified TPflash",
      "modifications": [
        "adaptive_switch_criterion",
        "trust_region_newton"
      ]
    }
  ],
  "eos_models": [
    {
      "name": "SRK",
      "class": "SystemSrkEos",
      "mixing_rule": "classic"
    }
  ],
  "random_seed": 42,
  "timing_repeats": 3,
  "convergence_tolerance": 1e-10,
  "max_ss_iterations": 50,
  "max_nr_iterations": 50,
  "max_rr_iterations": 300,
  "families": [
    {
      "name": "lean_gas",
      "base_composition": {
        "methane": 0.90,
        "ethane": 0.05,
        "propane": 0.03,
        "nitrogen": 0.01,
        "CO2": 0.01
      },
      "n_composition_variants": 5,
      "dirichlet_concentration": 50,
      "T_range_K": [200, 400],
      "P_range_bara": [1, 200],
      "n_T": 10,
      "n_P": 10,
      "note": "Mostly above critical — expect high convergence baseline"
    },
    {
      "name": "rich_gas",
      "base_composition": {
        "methane": 0.70,
        "ethane": 0.10,
        "propane": 0.08,
        "n-butane": 0.05,
        "n-pentane": 0.03,
        "nitrogen": 0.02,
        "CO2": 0.02
      },
      "n_composition_variants": 5,
      "dirichlet_concentration": 40,
      "T_range_K": [220, 450],
      "P_range_bara": [5, 300],
      "n_T": 10,
      "n_P": 10,
      "note": "Wider two-phase region — more challenging"
    },
    {
      "name": "gas_condensate",
      "base_composition": {
        "methane": 0.65,
        "ethane": 0.08,
        "propane": 0.06,
        "n-butane": 0.04,
        "n-pentane": 0.03,
        "n-hexane": 0.02,
        "n-heptane": 0.02,
        "n-decane": 0.05,
        "nitrogen": 0.02,
        "CO2": 0.03
      },
      "n_composition_variants": 5,
      "dirichlet_concentration": 30,
      "T_range_K": [250, 500],
      "P_range_bara": [10, 500],
      "n_T": 10,
      "n_P": 10,
      "note": "Highest Nc — most expensive per flash, near-critical issues expected"
    },
    {
      "name": "co2_rich",
      "base_composition": {
        "CO2": 0.85,
        "methane": 0.08,
        "ethane": 0.04,
        "H2S": 0.03
      },
      "n_composition_variants": 5,
      "dirichlet_concentration": 40,
      "T_range_K": [220, 400],
      "P_range_bara": [10, 300],
      "n_T": 10,
      "n_P": 10,
      "note": "CO2-dominated — non-ideal behavior near CO2 critical point (304 K, 74 bar)"
    },
    {
      "name": "wide_boiling",
      "base_composition": {
        "methane": 0.45,
        "ethane": 0.08,
        "propane": 0.06,
        "n-butane": 0.05,
        "n-pentane": 0.04,
        "n-hexane": 0.04,
        "n-heptane": 0.04,
        "n-octane": 0.04,
        "n-nonane": 0.03,
        "n-decane": 0.05,
        "C11": 0.04,
        "nitrogen": 0.08
      },
      "n_composition_variants": 5,
      "dirichlet_concentration": 25,
      "T_range_K": [280, 550],
      "P_range_bara": [5, 400],
      "n_T": 10,
      "n_P": 10,
      "note": "Large K-factor spread — tests RR solver robustness"
    },
    {
      "name": "sour_gas",
      "base_composition": {
        "methane": 0.75,
        "CO2": 0.10,
        "H2S": 0.10,
        "ethane": 0.05
      },
      "n_composition_variants": 5,
      "dirichlet_concentration": 40,
      "T_range_K": [250, 420],
      "P_range_bara": [10, 250],
      "n_T": 10,
      "n_P": 10,
      "note": "H2S near-critical at 373 K, 90 bar"
    }
  ],
  "stress_cases": {
    "near_critical": {
      "n_cases": 20,
      "method": "Generate compositions near mixture pseudo-critical, scan T +/- 5K around Tc",
      "families": ["lean_gas", "gas_condensate"]
    },
    "near_bubble": {
      "n_cases": 10,
      "method": "Phase envelope scan, select T,P with beta < 0.01"
    },
    "near_dew": {
      "n_cases": 10,
      "method": "Phase envelope scan, select T,P with beta > 0.99"
    },
    "trace_component": {
      "n_cases": 10,
      "method": "Set one component zi = 1e-5, redistribute remainder"
    }
  },
  "output": {
    "raw_results": "results/raw/{algorithm}_{family}.jsonl",
    "summary": "results/summary_{algorithm}.json",
    "metadata": "results/benchmark_metadata.json"
  }
}
