{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:neqsim:schema:engineering-vertical-slice-execution-manifest:v1",
  "title": "NeqSim engineering vertical-slice execution manifest",
  "type": "object",
  "required": [
    "schemaVersion",
    "schemaUri",
    "status",
    "projectId",
    "projectRevision",
    "designPolicyId",
    "designPolicyRevision",
    "designPolicyFingerprint",
    "qualificationPolicyId",
    "qualificationPolicyRevision",
    "qualificationPolicyFingerprint",
    "inputFingerprint",
    "caseDefinitions",
    "dynamicScenarios",
    "coupledStudies",
    "standards",
    "evidence",
    "preflightReady",
    "preflightBlockers",
    "fitnessForConstruction",
    "engineeringApprovalRequired"
  ],
  "properties": {
    "schemaVersion": { "const": "neqsim_engineering_vertical_slice_execution_manifest.v1" },
    "schemaUri": { "type": "string", "minLength": 1 },
    "status": { "enum": ["READY_FOR_SIMULATION", "BLOCKED", "NOT_CONFIGURED"] },
    "projectId": { "type": "string", "minLength": 1 },
    "projectRevision": { "type": "string", "minLength": 1 },
    "designPolicyId": { "type": "string", "minLength": 1 },
    "designPolicyRevision": { "type": "string", "minLength": 1 },
    "designPolicyFingerprint": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "qualificationPolicyId": { "type": "string", "minLength": 1 },
    "qualificationPolicyRevision": { "type": "string", "minLength": 1 },
    "qualificationPolicyFingerprint": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "inputFingerprint": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "caseDefinitions": { "type": "array", "items": { "type": "string" } },
    "dynamicScenarios": { "type": "array", "items": { "type": "string" } },
    "coupledStudies": { "type": "array", "items": { "type": "string" } },
    "standards": { "type": "array", "items": { "type": "string" } },
    "evidence": { "type": "array", "items": { "type": "string" } },
    "preflightReady": { "type": "boolean" },
    "preflightBlockers": { "type": "array", "items": { "type": "string" } },
    "fitnessForConstruction": { "const": false },
    "engineeringApprovalRequired": { "const": true }
  },
  "additionalProperties": false
}
